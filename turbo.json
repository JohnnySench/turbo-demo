{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "preview": {
      "dependsOn": ["^preview", "build"]
    },
    "test": {
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build", "preview"],
      "cache": false
    }
  }
}
